{
  "mcpServers": {
    "startd8": {
      "command": "/bin/sh",
      "args": ["-lc", "/Users/neilyashinsky/Documents/Startd8/mcp/startd8-mcp-builder/run_mcp.sh"],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "STARTD8_SKILL_PATH": "${env:STARTD8_SKILL_PATH}",
        "STARTD8_MCP_QUIET": "1",
        "STARTD8_MCP_REGISTER_SKILL_TOOLS": "1",
        "STARTD8_MCP_MAX_SKILL_TOOLS": "100",
        "STARTD8_MCP_LOG_FILE": "${env:STARTD8_MCP_LOG_FILE}",
        "STARTD8_MCP_DEBUG": "${env:STARTD8_MCP_DEBUG}",
        "STARTD8_MCP_SERVICE": "startd8-mcp",
        "STARTD8_MCP_ENV": "local",
        "STARTD8_MCP_VERSION": "0.1.0",
        "STARTD8_MCP_EVENT_LOG_FILE": "/Users/neilyashinsky/Documents/Startd8/mcp/startd8-mcp-builder/logs/mcp-events.jsonl",
        "STARTD8_MCP_METRICS_PORT": "9464",
        "STARTD8_MCP_METRICS_ADDR": "0.0.0.0",
        "STARTD8_MCP_TRACING": "1",
        "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT": "http://localhost:4318/v1/traces"
      }
    }
  }
}
