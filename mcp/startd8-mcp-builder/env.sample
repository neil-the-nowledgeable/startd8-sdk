# MCP task runner defaults
PROJECT_ROOT=/Users/neilyashinsky/Documents/Startd8/mcp/startd8-mcp-builder
TASK_LIST_PATH=MASTER_TASK_LIST.md
TASK_LOG_ENABLED=true
TASK_LOG_PATH=logs/task-execution.log
TASK_LOG_ROTATION_DAYS=14
TASK_LOG_MAX_BYTES=0
ALLOWED_AGENTS=mock
DEFAULT_AGENT=mock
ALLOW_AUTO_DEPS=true
AUTO_MAX_DEPTH=5
AUTO_MAX_TASKS=20
STARTD8_SDK_PATH=/Users/neilyashinsky/Documents/Startd8/dev/startd8-sdk-project/src
ALLOWED_EXTENSIONS=
BLOCKED_EXTENSIONS=.exe,.dll,.bat,.sh,.cmd,.com

# Skills scan roots
# Primary roots (colon-separated). If unset, `run_mcp.sh` will default to:
#   /Users/neilyashinsky/Documents/tools/Anthropic/context/Claude/Skills
# STARTD8_SKILL_PATH=/Users/neilyashinsky/Documents/tools/Anthropic/context/Claude/Skills
#
# Secondary roots (disabled by default). Enable with STARTD8_SKILL_PATH_SECONDARY_ENABLED=1.
# Default secondary (when enabled and STARTD8_SKILL_PATH_SECONDARY is unset):
#   /Users/neilyashinsky/Documents/FMLs/dev/version2/skill-react-game-enhancer
# STARTD8_SKILL_PATH_SECONDARY=/Users/neilyashinsky/Documents/FMLs/dev/version2/skill-react-game-enhancer
# STARTD8_SKILL_PATH_SECONDARY_ENABLED=0

# Optional keys
# ANTHROPIC_API_KEY=your_key_here

# Optional: MCP-safe stderr log capture
# STARTD8_MCP_LOG_FILE=/tmp/startd8-mcp.log

# Optional: structured event log (JSONL) for external observability
# STARTD8_MCP_EVENT_LOG_FILE=logs/mcp-events.jsonl
# STARTD8_MCP_LOG_JSON=0

# Optional: stable identity labels for observability (logs/metrics)
# STARTD8_MCP_SERVICE=startd8-mcp
# STARTD8_MCP_ENV=local
# STARTD8_MCP_VERSION=0.1.0

# Optional: Prometheus metrics endpoint (requires `pip install prometheus-client`)
# STARTD8_MCP_METRICS_PORT=9464
# STARTD8_MCP_METRICS_ADDR=127.0.0.1

# Optional: OpenTelemetry tracing (OTLP -> Alloy/Tempo)
# STARTD8_MCP_TRACING=1
# If using OTLP/HTTP (recommended for local), publish Alloy 4318 and set:
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Optional: startup/performance tuning
# STARTD8_MCP_REGISTER_SKILL_TOOLS=1
# STARTD8_MCP_MAX_SKILL_TOOLS=100
# STARTD8_MCP_STARTUP_MAX_SKILLS=100
# STARTD8_MCP_SKILL_CACHE_TTL_SECONDS=10
