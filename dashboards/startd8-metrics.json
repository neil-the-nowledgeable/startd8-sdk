          },
          "unit": "ms"
        }
      }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Sessions Near Capacity",
      "description": "Sessions with >80% context usage",
      "gridPos": { "x": 12, "y": 52, "w": 6, "h": 4 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "count(startd8_context_usage_ratio{agent_name=~\"$agent_name\", model=~\"$model\"} > 0.8)",
          "legendFormat": "Near Capacity"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Truncation Rate",
      "description": "Truncations per 100 requests",
      "gridPos": { "x": 18, "y": 52, "w": 6, "h": 4 },
