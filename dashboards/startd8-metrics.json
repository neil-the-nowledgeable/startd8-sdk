          "expr": "sum(rate(startd8_truncations_total{agent_name=~\"$agent_name\", model=~\"$model\"}[24h])) / sum(rate(startd8_requests_total{agent_name=~\"$agent_name\", model=~\"$model\"}[24h])) * 100",
          "legendFormat": "Rate"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        }
      }
    },
    {
      "type": "row",
      "title": "Detailed Metrics Table",
      "gridPos": { "x": 0, "y": 56, "w": 24, "h": 1 },
      "collapsed": true,
      "panels": [
