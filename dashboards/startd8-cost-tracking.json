{
  "uid": "startd8-cost-tracking",
  "title": "StartD8 Cost Tracking",
  "description": "Cost tracking dashboard for StartD8 SDK — spend by model, budget alerts, token efficiency, and cost-per-request analysis",
  "tags": ["startd8", "sdk", "cost-tracking", "llm", "budget"],
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "__inputs": [
    {
      "name": "DS_MIMIR",
      "label": "Mimir",
      "description": "Prometheus-compatible metrics datasource (Mimir or Prometheus)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki log aggregation datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "histogram",
      "name": "Histogram",
      "version": ""
    },
    {
      "type": "panel",
      "id": "logs",
      "name": "Logs",
      "version": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service_name",
        "label": "Service",
        "type": "custom",
        "query": "startd8-sdk",
        "current": {
          "text": "startd8-sdk",
          "value": "startd8-sdk",
          "selected": true
        },
        "options": [
          {
            "text": "startd8-sdk",
            "value": "startd8-sdk",
            "selected": true
          }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_MIMIR}"
        },
        "query": "label_values(startd8_cost_total{service_name=~\"$service_name\"}, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "hide": 0
      },
      {
        "name": "project_id",
        "label": "Project",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_MIMIR}"
        },
        "query": "label_values(startd8_cost_total{service_name=~\"$service_name\"}, project_id)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Spend",
      "description": "Total cumulative spend across all models and projects",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "sum(startd8_cost_total{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"})",
          "legendFormat": "Total Spend",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 2,
      "title": "Spend by Model",
      "description": "Breakdown of total spend per model",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 10,
        "w": 10,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "pieType": "pie",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showPercent": true,
          "values": ["value", "percent"],
          "calcs": ["lastNotNull"]
        },
        "displayLabels": ["name", "percent"]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "sum by (model)(startd8_cost_total{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"})",
          "legendFormat": "{{model}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Budget Utilization",
      "description": "Current budget usage percentage",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "orange",
                "value": 0.85
              },
              {
                "color": "red",
                "value": 0.95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "sum(startd8_cost_total{service_name=~\"$service_name\", project_id=~\"$project_id\"}) / sum(startd8_budget_limit{service_name=~\"$service_name\", project_id=~\"$project_id\"})",
          "legendFormat": "Budget Used",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Count",
      "description": "Total number of LLM requests",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "sum(increase(startd8_cost_total{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}[$__range]))",
          "legendFormat": "Requests",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "title": "Avg Cost Per Request",
      "description": "Average cost per LLM request",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.25
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "sum(startd8_cost_per_request_bucket{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}) / count(startd8_cost_per_request_bucket{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"})",
          "legendFormat": "Avg Cost/Request",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 6,
      "title": "Spend Over Time",
      "description": "Cost rate per model over time (5-minute rolling rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum", "mean", "max"],
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "sum by (model)(rate(startd8_cost_total{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}[5m]))",
          "legendFormat": "{{model}}",
          "instant": false,
          "range": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Spend Over Time (Cumulative)",
      "description": "Cumulative spend stacked by model",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "sum by (model)(startd8_cost_total{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"})",
          "legendFormat": "{{model}}",
          "instant": false,
          "range": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Cost Per Request",
      "description": "Distribution of cost per individual LLM request (histogram buckets)",
      "type": "histogram",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "bucketOffset": 0,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "none",
        "bucketSize": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "startd8_cost_per_request_bucket{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}",
          "legendFormat": "{{le}}",
          "instant": false,
          "range": true,
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 9,
      "title": "Token Efficiency",
      "description": "Input vs output token rates over time (5-minute rolling rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "tokens/sec",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Input Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Output Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum", "mean", "max"],
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "rate(startd8_cost_input_tokens{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}[5m])",
          "legendFormat": "Input Tokens",
          "instant": false,
          "range": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "rate(startd8_cost_output_tokens{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}[5m])",
          "legendFormat": "Output Tokens",
          "instant": false,
          "range": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Input/Output Token Ratio",
      "description": "Ratio of input to output tokens -- higher values mean more context, lower means more generation",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_MIMIR}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "input:output ratio",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_MIMIR}"
          },
          "expr": "rate(startd8_cost_input_tokens{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}[5m]) / rate(startd8_cost_output_tokens{service_name=~\"$service_name\", model=~\"$model\", project_id=~\"$project_id\"}[5m])",
          "legendFormat": "{{model}}",
          "instant": false,
          "range": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Budget Alerts",
      "description": "Log entries related to budget warnings and alerts from Loki",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "{service_name=\"$service_name\"} |= \"budget\"",
          "queryType": "range",
          "maxLines": 200
        }
      ]
    }
  ],
  "links": [
    {
      "title": "StartD8 SDK Metrics",
      "url": "/d/startd8-sdk-metrics/startd8-sdk-metrics",
      "tooltip": "Go to the main SDK metrics dashboard",
      "icon": "dashboard",
      "type": "link",
      "asDropdown": false,
      "tags": [],
      "targetBlank": false
    }
  ],
  "version": 1
}
