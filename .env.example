# =============================================================================
# StartD8 SDK — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in the values you need.
# .env is already in .gitignore.

# ---------------------------------------------------------------------------
# LLM Provider API Keys
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# MISTRAL_API_KEY=...
# OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# OpenTelemetry Configuration
# ---------------------------------------------------------------------------
#
# Mode (STARTD8_OTEL):
#   auto     (default) — configure OTel only when a collector is reachable.
#                         Resolution cascade:
#                           1. OTEL_EXPORTER_OTLP_ENDPOINT env var
#                           2. ~/.startd8/config.json -> otel.endpoint
#                           3. Auto-probe http://localhost:4317
#                         If none is reachable, telemetry is silently skipped.
#   enabled  — always configure OTel (defaults to http://localhost:4317).
#   disabled — do nothing, no OTel overhead.
#
# STARTD8_OTEL=auto

# OTLP exporter endpoint (gRPC). Set this if your collector is not on
# localhost:4317 — e.g. a remote Alloy, OTel Collector, or Grafana Cloud.
#
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Fail-fast policy — in CI, enabled mode + missing endpoint = startup error.
# Also auto-enabled when CI=true.
#
# STARTD8_OTEL_FAIL_FAST=false

# Hard-fail — raise RuntimeError instead of logging and continuing.
# Only useful for development/debugging.
#
# STARTD8_OTEL_HARD_FAIL=false

# ---------------------------------------------------------------------------
# Persistent OTel Configuration (alternative to env vars)
# ---------------------------------------------------------------------------
#
# Instead of setting env vars in every shell, you can persist OTel settings:
#
#   startd8 otel-configure --endpoint http://localhost:4317
#   startd8 otel-configure --mode auto
#
# Settings are stored in ~/.startd8/config.json and survive shell restarts.
# Env vars always take priority over config file values.
#
# Check current status:
#   startd8 otel-status
