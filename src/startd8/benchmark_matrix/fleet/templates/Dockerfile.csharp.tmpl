# Round-3 M0 per-language Dockerfile TEMPLATE — C# / .NET service.
#
# Mirrors the canonical cartservice Dockerfile (dotnet/sdk builder publishing → minimal runtime),
# reusing the provision.publish_dotnet_service stance: the harness co-locates demo.proto into the
# project dir, Grpc.Tools codegen runs the C# server stubs from it at publish time, and
# <AssemblyName>server</AssemblyName> makes the entry binary server.dll.
#
# OFFLINE NOTE (OQ-C6 — the one load-bearing reuse gap): `dotnet restore` is the ONLY network step.
# v1 builds with network (restore over NuGet); the warm-NuGet-cache bake (snapshot ~/.nuget into the
# build context, then `dotnet publish --no-restore`) for a hermetic `--network=none` build is DEFERRED.
# We use framework-dependent publish (not the upstream PublishSingleFile/self-contained/trimmed) →
# smaller build, runs on the dotnet runtime image; both are valid canonical targets.
#
# Parameters filled by the builder:
#   {DOTNET_SDK}      sdk builder image (digest-pinnable)
#   {DOTNET_RUNTIME}  aspnet runtime image (framework-dependent run)
#   {PORT}            gRPC listen port (server reads $PORT / ASPNETCORE_URLS)
#
# Context layout (staged by build_service_image -> _stage_csharp_context):
#   ./*.csproj        harness-owned project (AssemblyName=server, <Protobuf> demo.proto)
#   ./*.cs            generated C# source
#   ./demo.proto      co-located OB contract for Grpc.Tools codegen

FROM {DOTNET_SDK} AS build
WORKDIR /src
COPY . .
ENV DOTNET_CLI_TELEMETRY_OPTOUT=1 DOTNET_NOLOGO=1 DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
# arm64 protoc fix (OQ-C4): Grpc.Tools 2.71's bundled tools/linux_arm64/protoc SIGSEGVs (exit 139)
# under the MSBuild Protobuf_Compile invocation (which adds --dependency_out) on this host — verified
# deterministic. The binary itself is fine (protoc --version + a manual --csharp_out/--grpc_out codegen
# of demo.proto both succeed); only the MSBuild call path crashes it. The system protoc (apt) +
# Grpc.Tools' own grpc_csharp_plugin codegen demo.proto cleanly, so point Grpc.Tools at the system
# protoc via Protobuf_ProtocFullPath. Harmless on amd64 (where the bundled protoc works); proto3 has
# no external imports so the standard-imports path (still Grpc.Tools') needs no change.
RUN apt-get update && apt-get install -y --no-install-recommends protobuf-compiler && rm -rf /var/lib/apt/lists/*
RUN dotnet publish -c Release -o /out --nologo -p:Protobuf_ProtocFullPath=/usr/bin/protoc

FROM {DOTNET_RUNTIME}
WORKDIR /app
COPY --from=build /out/ /app/
ENV PORT={PORT}
ENV ASPNETCORE_URLS=http://0.0.0.0:{PORT}
EXPOSE {PORT}
ENTRYPOINT ["dotnet", "/app/server.dll"]
