    WorkflowMetadata,
    WorkflowInput,
    WorkflowResult,
    WorkflowMetrics,
    StepResult,
    AgentCount,
    ValidationResult,
)
from ...agents import BaseAgent


class {{ class_name }}(WorkflowBase):
    """
    {{ description }}

    This is a basic single-agent workflow. Customize the metadata
    and _execute method to implement your workflow logic.

    Example:
        workflow = {{ class_name }}()
        result = workflow.run(
            config={"input_text": "Hello, world!"},
            agents=[my_agent],
        )
    """

    @property
    def metadata(self) -> WorkflowMetadata:
        return WorkflowMetadata(
            workflow_id="{{ workflow_id }}",
            name="{{ name }}",
            description="{{ description }}",
            version="{{ version }}",
            capabilities={{ capabilities }},
            tags={{ tags }},
            requires_agents=True,
            agent_count=AgentCount.SINGLE,
            min_agents=1,
            max_agents=1,
            inputs=[
                WorkflowInput(
                    name="input_text",
                    type="text",
                    required=True,
                    description="The input text to process",
                ),
            ],
        )

    def validate_config(self, config: Dict[str, Any]) -> ValidationResult:
        """Validate workflow configuration."""
        errors = []

        if "input_text" not in config:
            errors.append("Missing required input: input_text")

        # Add custom validation here

        if errors:
            return ValidationResult.failure(errors)
        return ValidationResult.success()

    def _execute(
        self,
        config: Dict[str, Any],
        agents: Optional[List[BaseAgent]],
        on_progress: Optional[ProgressCallback],
    ) -> WorkflowResult:
        """Execute the workflow."""
        started_at = datetime.now()

        # Get input
        input_text = config["input_text"]

        # Get agent
        if not agents or len(agents) < 1:
            return WorkflowResult.from_error(
                self.metadata.workflow_id,
                "At least one agent is required",
            )
        agent = agents[0]

        # Report progress
        self._emit_progress(on_progress, 0, 1, "Starting workflow")

        # Execute agent
        try:
            response = agent.send(input_text)
            output = response.response
            time_ms = response.response_time_ms
            input_tokens = response.token_usage.prompt if response.token_usage else 0
            output_tokens = response.token_usage.completion if response.token_usage else 0
            cost = response.token_usage.cost_estimate if response.token_usage else 0.0
        except Exception as e:
            return WorkflowResult.from_error(
                self.metadata.workflow_id,
                f"Agent execution failed: {e}",
            )

        # Report completion
        self._emit_progress(on_progress, 1, 1, "Workflow complete")

        completed_at = datetime.now()

        # Build result
        step_result = StepResult(
            step_name="process",
            agent_name=agent.name,
            input=input_text,
            output=output,
            time_ms=time_ms,
            input_tokens=input_tokens,
            output_tokens=output_tokens,
            cost=cost,
        )

        metrics = WorkflowMetrics(
            total_time_ms=time_ms,
            input_tokens=input_tokens,
            output_tokens=output_tokens,
            total_cost=cost,
            step_count=1,
        )

        return WorkflowResult(
            workflow_id=self.metadata.workflow_id,
            success=True,
            output=output,
            metrics=metrics,
            steps=[step_result],
            started_at=started_at,
            completed_at=completed_at,
        )
