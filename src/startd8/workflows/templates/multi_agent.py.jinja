from datetime import datetime
from typing import Any, Dict, List, Optional
import concurrent.futures

from ..base import WorkflowBase, ProgressCallback
from ..models import (
    WorkflowMetadata,
    WorkflowInput,
    WorkflowResult,
    WorkflowMetrics,
    StepResult,
    AgentCount,
    ValidationResult,
)
from ...agents import BaseAgent


class {{ class_name }}(WorkflowBase):
    """
    {{ description }}

    This is a multi-agent workflow that runs agents in parallel and
    aggregates their results. Customize the aggregation logic in _execute.

    Example:
        workflow = {{ class_name }}()
        result = workflow.run(
            config={"task": "Analyze this document"},
            agents=[analyst1, analyst2, analyst3],
        )
    """

    @property
    def metadata(self) -> WorkflowMetadata:
        return WorkflowMetadata(
            workflow_id="{{ workflow_id }}",
            name="{{ name }}",
            description="{{ description }}",
            version="{{ version }}",
            capabilities={{ capabilities }},
            tags={{ tags }},
            requires_agents=True,
            agent_count=AgentCount.MULTIPLE,
            min_agents=2,
            max_agents=None,
            inputs=[
                WorkflowInput(
                    name="task",
                    type="text",
                    required=True,
                    description="The task for all agents to work on",
                ),
            ],
        )

    def validate_config(self, config: Dict[str, Any]) -> ValidationResult:
        """Validate workflow configuration."""
        errors = []

        if "task" not in config:
            errors.append("Missing required input: task")

        agents = config.get("agents", [])
        if len(agents) < 2:
            errors.append("Multi-agent workflow requires at least 2 agents")

        if errors:
            return ValidationResult.failure(errors)
        return ValidationResult.success()

    def _execute_agent(
        self,
        agent: BaseAgent,
        task: str,
        agent_index: int,
    ) -> StepResult:
        """Execute a single agent (for parallel execution)."""
        step_name = f"agent-{agent_index + 1}"

        try:
            response = agent.send(task)
            return StepResult(
                step_name=step_name,
                agent_name=agent.name,
                input=task[:500],
                output=response.response,
                time_ms=response.response_time_ms,
                input_tokens=response.token_usage.prompt if response.token_usage else 0,
                output_tokens=response.token_usage.completion if response.token_usage else 0,
                cost=response.token_usage.cost_estimate if response.token_usage else 0.0,
            )
        except Exception as e:
            return StepResult(
                step_name=step_name,
                agent_name=agent.name,
                error=str(e),
            )

    def _aggregate_results(self, step_results: List[StepResult]) -> str:
        """
        Aggregate results from multiple agents.

        Override this method to customize aggregation logic.
        Default: concatenate all outputs with headers.
        """
        outputs = []
        for result in step_results:
            if result.success:
                outputs.append(f"## {result.agent_name}\n\n{result.output}")
            else:
                outputs.append(f"## {result.agent_name}\n\n[Error: {result.error}]")

        return "\n\n---\n\n".join(outputs)

    def _execute(
        self,
        config: Dict[str, Any],
        agents: Optional[List[BaseAgent]],
        on_progress: Optional[ProgressCallback],
    ) -> WorkflowResult:
        """Execute agents in parallel and aggregate results."""
        started_at = datetime.now()

        if not agents or len(agents) < 2:
            return WorkflowResult.from_error(
                self.metadata.workflow_id,
                "Multi-agent workflow requires at least 2 agents",
            )

        task = config["task"]
        total_agents = len(agents)

        self._emit_progress(on_progress, 0, total_agents, "Starting parallel execution")

        # Execute agents in parallel using ThreadPoolExecutor
        step_results: List[StepResult] = []
        with concurrent.futures.ThreadPoolExecutor(max_workers=total_agents) as executor:
            futures = {
                executor.submit(self._execute_agent, agent, task, i): i
                for i, agent in enumerate(agents)
            }

            for future in concurrent.futures.as_completed(futures):
                agent_index = futures[future]
                try:
                    result = future.result()
                    step_results.append(result)
                    self._emit_progress(
                        on_progress,
                        len(step_results),
                        total_agents,
                        f"Completed agent-{agent_index + 1}",
                    )
                except Exception as e:
                    step_results.append(StepResult(
                        step_name=f"agent-{agent_index + 1}",
                        error=str(e),
                    ))

        # Sort by agent index for consistent ordering
        step_results.sort(key=lambda r: r.step_name)

        # Check for failures
        failures = [r for r in step_results if not r.success]
        if len(failures) == len(step_results):
            return WorkflowResult.from_error(
                self.metadata.workflow_id,
                "All agents failed",
                steps=step_results,
            )

        # Aggregate results
        aggregated_output = self._aggregate_results(step_results)

        completed_at = datetime.now()

        # Aggregate metrics
        metrics = WorkflowMetrics(
            total_time_ms=max(s.time_ms for s in step_results if s.success) if any(s.success for s in step_results) else 0,
            input_tokens=sum(s.input_tokens for s in step_results),
            output_tokens=sum(s.output_tokens for s in step_results),
            total_cost=sum(s.cost for s in step_results),
            step_count=len(step_results),
        )

        return WorkflowResult(
            workflow_id=self.metadata.workflow_id,
            success=True,
            output=aggregated_output,
            metrics=metrics,
            steps=step_results,
            started_at=started_at,
            completed_at=completed_at,
            metadata={
                "successful_agents": len(step_results) - len(failures),
                "failed_agents": len(failures),
            },
        )
