import asyncio
from datetime import datetime
from typing import Any, Dict, List, Optional

from ..base import WorkflowBase, ProgressCallback
from ..models import (
    WorkflowMetadata,
    WorkflowInput,
    WorkflowResult,
    WorkflowMetrics,
    StepResult,
    AgentCount,
    ValidationResult,
)
from ...agents import BaseAgent


class {{ class_name }}(WorkflowBase):
    """
    {{ description }}

    This is an async-first workflow implementation that uses
    asyncio for concurrent operations. Customize _aexecute.

    Example:
        workflow = {{ class_name }}()

        # Async usage
        result = await workflow.arun(
            config={"input_text": "Process this"},
            agents=[agent],
        )

        # Sync usage (wraps async automatically)
        result = workflow.run(
            config={"input_text": "Process this"},
            agents=[agent],
        )
    """

    @property
    def metadata(self) -> WorkflowMetadata:
        return WorkflowMetadata(
            workflow_id="{{ workflow_id }}",
            name="{{ name }}",
            description="{{ description }}",
            version="{{ version }}",
            capabilities={{ capabilities }},
            tags={{ tags }},
            requires_agents=True,
            agent_count=AgentCount.CONFIGURABLE,
            min_agents=1,
            max_agents=None,
            inputs=[
                WorkflowInput(
                    name="input_text",
                    type="text",
                    required=True,
                    description="The input text to process",
                ),
            ],
        )

    def validate_config(self, config: Dict[str, Any]) -> ValidationResult:
        """Validate workflow configuration."""
        errors = []

        if "input_text" not in config:
            errors.append("Missing required input: input_text")

        if errors:
            return ValidationResult.failure(errors)
        return ValidationResult.success()

    async def _execute_agent_async(
        self,
        agent: BaseAgent,
        input_text: str,
        step_name: str,
    ) -> StepResult:
        """Execute a single agent asynchronously."""
        try:
            # Use async send if available, otherwise run in executor
            if hasattr(agent, 'asend'):
                response = await agent.asend(input_text)
            else:
                loop = asyncio.get_event_loop()
                response = await loop.run_in_executor(
                    None,
                    lambda: agent.send(input_text),
                )

            return StepResult(
                step_name=step_name,
                agent_name=agent.name,
                input=input_text[:500],
                output=response.response,
                time_ms=response.response_time_ms,
                input_tokens=response.token_usage.prompt if response.token_usage else 0,
                output_tokens=response.token_usage.completion if response.token_usage else 0,
                cost=response.token_usage.cost_estimate if response.token_usage else 0.0,
            )
        except Exception as e:
            return StepResult(
                step_name=step_name,
                agent_name=agent.name,
                error=str(e),
            )

    async def _aexecute(
        self,
        config: Dict[str, Any],
        agents: Optional[List[BaseAgent]],
        on_progress: Optional[ProgressCallback],
    ) -> WorkflowResult:
        """Execute the workflow asynchronously."""
        started_at = datetime.now()

        if not agents or len(agents) < 1:
            return WorkflowResult.from_error(
                self.metadata.workflow_id,
                "At least one agent is required",
            )

        input_text = config["input_text"]
        total_steps = len(agents)

        self._emit_progress(on_progress, 0, total_steps, "Starting async workflow")

        # Execute all agents concurrently
        tasks = [
            self._execute_agent_async(agent, input_text, f"step-{i + 1}")
            for i, agent in enumerate(agents)
        ]

        step_results = await asyncio.gather(*tasks, return_exceptions=False)

        # Report progress for each completed step
        for i, result in enumerate(step_results):
            self._emit_progress(
                on_progress,
                i + 1,
                total_steps,
                f"Completed {result.step_name}",
            )

        completed_at = datetime.now()

        # Check for failures
        successful = [r for r in step_results if r.success]
        if not successful:
            return WorkflowResult.from_error(
                self.metadata.workflow_id,
                "All agents failed",
                steps=step_results,
            )

        # Use first successful result as output (customize as needed)
        primary_output = successful[0].output

        # Aggregate metrics
        metrics = WorkflowMetrics(
            total_time_ms=max(s.time_ms for s in successful),
            input_tokens=sum(s.input_tokens for s in step_results),
            output_tokens=sum(s.output_tokens for s in step_results),
            total_cost=sum(s.cost for s in step_results),
            step_count=len(step_results),
        )

        return WorkflowResult(
            workflow_id=self.metadata.workflow_id,
            success=True,
            output=primary_output,
            metrics=metrics,
            steps=step_results,
            started_at=started_at,
            completed_at=completed_at,
            metadata={
                "concurrent_agents": len(agents),
                "successful_agents": len(successful),
            },
        )
