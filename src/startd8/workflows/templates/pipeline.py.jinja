from datetime import datetime
from typing import Any, Dict, List, Optional

from ..base import WorkflowBase, ProgressCallback
from ..models import (
    WorkflowMetadata,
    WorkflowInput,
    WorkflowResult,
    WorkflowMetrics,
    StepResult,
    AgentCount,
    ValidationResult,
)
from ...agents import BaseAgent


class {{ class_name }}(WorkflowBase):
    """
    {{ description }}

    This is a sequential pipeline workflow where output from each step
    flows into the next step. Customize the steps in _execute.

    Example:
        workflow = {{ class_name }}()
        result = workflow.run(
            config={"initial_input": "Start here"},
            agents=[agent1, agent2, agent3],
        )
    """

    @property
    def metadata(self) -> WorkflowMetadata:
        return WorkflowMetadata(
            workflow_id="{{ workflow_id }}",
            name="{{ name }}",
            description="{{ description }}",
            version="{{ version }}",
            capabilities={{ capabilities }},
            tags={{ tags }},
            requires_agents=True,
            agent_count=AgentCount.CONFIGURABLE,
            min_agents=2,
            max_agents=None,  # Unlimited
            inputs=[
                WorkflowInput(
                    name="initial_input",
                    type="text",
                    required=True,
                    description="The input to start the pipeline",
                ),
            ],
        )

    def validate_config(self, config: Dict[str, Any]) -> ValidationResult:
        """Validate workflow configuration."""
        errors = []

        if "initial_input" not in config:
            errors.append("Missing required input: initial_input")

        # Check agent count
        agents = config.get("agents", [])
        if len(agents) < 2:
            errors.append("Pipeline requires at least 2 agents")

        if errors:
            return ValidationResult.failure(errors)
        return ValidationResult.success()

    def _execute(
        self,
        config: Dict[str, Any],
        agents: Optional[List[BaseAgent]],
        on_progress: Optional[ProgressCallback],
    ) -> WorkflowResult:
        """Execute the pipeline sequentially."""
        started_at = datetime.now()

        if not agents or len(agents) < 2:
            return WorkflowResult.from_error(
                self.metadata.workflow_id,
                "Pipeline requires at least 2 agents",
            )

        # Initial input flows through pipeline
        current_input = config["initial_input"]
        step_results: List[StepResult] = []
        total_steps = len(agents)

        self._emit_progress(on_progress, 0, total_steps, "Starting pipeline")

        # Execute each agent in sequence
        for i, agent in enumerate(agents):
            step_name = f"step-{i + 1}"

            try:
                response = agent.send(current_input)
                output = response.response
                time_ms = response.response_time_ms
                input_tokens = response.token_usage.prompt if response.token_usage else 0
                output_tokens = response.token_usage.completion if response.token_usage else 0
                cost = response.token_usage.cost_estimate if response.token_usage else 0.0

                step_result = StepResult(
                    step_name=step_name,
                    agent_name=agent.name,
                    input=current_input[:500],  # Truncate for storage
                    output=output,
                    time_ms=time_ms,
                    input_tokens=input_tokens,
                    output_tokens=output_tokens,
                    cost=cost,
                )
                step_results.append(step_result)

                # Output becomes input for next step
                current_input = output

                self._emit_progress(
                    on_progress,
                    i + 1,
                    total_steps,
                    f"Completed {step_name} ({agent.name})",
                )

            except Exception as e:
                # Record failed step
                step_results.append(StepResult(
                    step_name=step_name,
                    agent_name=agent.name,
                    error=str(e),
                ))
                return WorkflowResult.from_error(
                    self.metadata.workflow_id,
                    f"Pipeline failed at {step_name}: {e}",
                    steps=step_results,
                )

        completed_at = datetime.now()

        # Aggregate metrics
        metrics = WorkflowMetrics(
            total_time_ms=sum(s.time_ms for s in step_results),
            input_tokens=sum(s.input_tokens for s in step_results),
            output_tokens=sum(s.output_tokens for s in step_results),
            total_cost=sum(s.cost for s in step_results),
            step_count=len(step_results),
        )

        return WorkflowResult(
            workflow_id=self.metadata.workflow_id,
            success=True,
            output=current_input,  # Final output
            metrics=metrics,
            steps=step_results,
            started_at=started_at,
            completed_at=completed_at,
        )
