          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "mimir"
                      },
                      "group": "mimir",
                      "kind": "DataQuery",
                      "spec": {
                        "expr": "kickoff_readiness_percent{project=\"demo\"}",
                        "queryType": "range"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
