{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "m0-composite-probe",
    "namespace": "default"
  },
  "spec": {
    "annotations": [],
    "cursorSync": "Off",
    "description": "tabs+sectionvar+conditional",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "tempo"
                      },
                      "group": "tempo",
                      "kind": "DataQuery",
                      "spec": {
                        "limit": 100,
                        "query": "{resource.project.id != \"\"} | select(resource.project.id)",
                        "queryType": "traceql"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 1,
          "links": [],
          "title": "Projects with Activity",
          "vizConfig": {
            "group": "table",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "custom": {
                    "align": "auto",
                    "cellOptions": {
                      "type": "auto"
                    },
                    "footer": {
                      "reducers": []
                    },
                    "inspect": false
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      },
                      {
                        "color": "red",
                        "value": 80
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "cellHeight": "sm",
                "showHeader": true
              }
            },
            "version": "12.3.0"
          }
        }
      }
    },
    "layout": {
      "kind": "TabsLayout",
      "spec": {
        "tabs": [
          {
            "kind": "TabsLayoutTab",
            "spec": {
              "conditionalRendering": {
                "kind": "ConditionalRenderingGroup",
                "spec": {
                  "condition": "and",
                  "items": [
                    {
                      "kind": "ConditionalRenderingVariable",
                      "spec": {
                        "operator": "equals",
                        "value": "advanced",
                        "variable": "audience"
                      }
                    }
                  ],
                  "visibility": "show"
                }
              },
              "layout": {
                "kind": "GridLayout",
                "spec": {
                  "items": [
                    {
                      "kind": "GridLayoutItem",
                      "spec": {
                        "element": {
                          "kind": "ElementReference",
                          "name": "panel-1"
                        },
                        "height": 6,
                        "width": 24,
                        "x": 0,
                        "y": 0
                      }
                    }
                  ]
                }
              },
              "title": "Advanced",
              "variables": [
                {
                  "kind": "CustomVariable",
                  "spec": {
                    "allowCustomValue": false,
                    "current": {
                      "text": "low",
                      "value": "low"
                    },
                    "hide": "dontHide",
                    "includeAll": false,
                    "multi": false,
                    "name": "detail",
                    "options": [
                      {
                        "selected": true,
                        "text": "low",
                        "value": "low"
                      },
                      {
                        "selected": false,
                        "text": "high",
                        "value": "high"
                      }
                    ],
                    "query": "low,high",
                    "skipUrlSync": false
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "links": [],
    "liveNow": false,
    "preload": false,
    "tags": [
      "m0-spike"
    ],
    "timeSettings": {
      "autoRefresh": "30s",
      "autoRefreshIntervals": [
        "5s",
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ],
      "fiscalYearStartMonth": 0,
      "from": "now-7d",
      "hideTimepicker": false,
      "to": "now"
    },
    "title": "M0 composite probe",
    "variables": [
      {
        "kind": "CustomVariable",
        "spec": {
          "allowCustomValue": false,
          "current": {
            "text": "intermediate",
            "value": "intermediate"
          },
          "hide": "dontHide",
          "includeAll": false,
          "multi": false,
          "name": "audience",
          "options": [
            {
              "selected": false,
              "text": "beginner",
              "value": "beginner"
            },
            {
              "selected": true,
              "text": "intermediate",
              "value": "intermediate"
            },
            {
              "selected": false,
              "text": "advanced",
              "value": "advanced"
            }
          ],
          "query": "beginner,intermediate,advanced",
          "skipUrlSync": false
        }
      }
    ]
  },
  "status": {}
}