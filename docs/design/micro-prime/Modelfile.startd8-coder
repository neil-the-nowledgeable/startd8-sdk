FROM qwen2.5-coder:7b

# ── Context window: file-whole prompts need skeleton + output tokens ──
# Default Ollama num_ctx=2048 is too small for file-whole (skeleton + 2048 output).
# OLLAMA_QUALITY_RESEARCH_AGENDA Section 9.
PARAMETER num_ctx 8192

# ── Repetition control: prevent degenerate loops ──
# Reduced from 1.1/128 to 1.05/64 — code legitimately repeats self., return,
# if/elif patterns. High penalty degrades code quality. Validate empirically
# per OLLAMA_QUALITY_RESEARCH_AGENDA Section 4.
PARAMETER repeat_penalty 1.05
PARAMETER repeat_last_n 64

# ── NOTE: The following are ALL overridden by per-call API parameters ──
# in engine.py (_generate_ollama) and have NO effect at runtime:
#
#   SYSTEM prompt   → overridden by _ELEMENT_BODY_SYSTEM_PROMPT / _FILE_WHOLE_SYSTEM_PROMPT
#   temperature     → overridden by MicroPrimeConfig.temperature (0.1)
#   top_p / top_k   → not sent per-call; Ollama uses its own defaults when
#                      the OpenAI-compatible API doesn't pass them
#   num_predict     → overridden by max_tokens in API call (2048 for element, variable for file-whole)
#   stop sequences  → overridden by _OLLAMA_STOP_SEQUENCES / _FILE_WHOLE_STOP_SEQUENCES
#
# The real system prompts live in engine.py:_ELEMENT_BODY_SYSTEM_PROMPT and
# _FILE_WHOLE_SYSTEM_PROMPT. Edit those, not a SYSTEM directive here.
