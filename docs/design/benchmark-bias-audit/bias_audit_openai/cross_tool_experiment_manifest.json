{
  "schema_version": "1.0",
  "experiment_id": "pricing-cross-tool-authoring-v1",
  "status": "pre_registered",
  "purpose": "Measure author-vendor input divergence without treating the OpenAI generation smoke result as a bias verdict.",
  "source_artifacts": [
    {
      "id": "neutral_brief",
      "path": "docs/design/benchmark-bias-audit/bias_audit_openai/brief/pricing-task-brief.md",
