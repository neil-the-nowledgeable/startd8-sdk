    },
    "mastodonweb": {
      "service_id": "mastodonweb",
      "service_name": "mastodon/web",
      "transport": "http",
      "traces": true,
      "metrics_surface": "traces_only",
      "metrics": {"convention_based": [{"name": "http.server.duration", "type": "histogram", "source": "otel_semconv:http"}]}
    },
    "mastodonsidekiq": {
      "service_id": "mastodonsidekiq",
      "service_name": "mastodon/sidekiq",
      "transport": "http",
      "traces": true,
      "metrics_surface": "traces_only",
      "metrics": {"convention_based": [{"name": "http.server.duration", "type": "histogram", "source": "otel_semconv:http"}]}
    },
    "mastodonstreaming": {
      "service_id": "mastodonstreaming",
      "service_name": "mastodon/streaming",
      "transport": "http",
      "traces": true,
      "metrics_surface": "otel_sdk_meter",
      "metrics": {"convention_based": [{"name": "http.server.duration", "type": "histogram", "source": "otel_semconv:http"}]}
